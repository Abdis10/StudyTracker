# ---------------------------
# MAVEN & JAVA BUILD FILES
# ---------------------------
target/
*.class
*.log

# Allow Maven wrapper JAR only
!.mvn/wrapper/maven-wrapper.jar

# Prevent nested target folders except in source directories
!**/src/main/**/target/
!**/src/test/**/target/

# ---------------------------
# IDE: INTELLIJ IDEA
# ---------------------------
.idea/*
!.idea/runConfigurations*.iws
*.iml
*.ipr

# Older IntelliJ configs that create noise
.idea/modules.xml
.idea/jarRepositories.xml
.idea/compiler.xml
.idea/libraries/

# ---------------------------
# IDE: Eclipse (just in case)
# ---------------------------
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# ---------------------------
# IDE: NetBeans
# ---------------------------
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

build/
!**/src/main/**/build/
!**/src/test/**/build/

# ---------------------------
# VS CODE
# ---------------------------
.vscode/

# ---------------------------
# DATABASES (SQLite)
# ---------------------------
*.db
*.sqlite
*.db-journal
*.sqlite3

# If you store DB in a folder (recommended)
database/*.db

# ---------------------------
# OS FILES
# ---------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ---------------------------
# TEMP FILES
# ---------------------------
*.tmp
*.bak
*.swp
*.swo

# ---------------------------
# FRONTEND (Node / Vite / React)
# ---------------------------

# Node dependencies
node_modules/

# Vite production builds
dist/
dist-ssr/

# Environment variables
.env
.env.*

# NPM/Yarn/Pnpm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
